# Portail Unifié — Variables d'environnement

# Port du serveur (Railway le remplace automatiquement)
PORT=3010

# Secret JWT (changez impérativement en production !)
JWT_SECRET=changez_ce_secret_en_production_32_chars_minimum

# Credentials du Super Admin (créé automatiquement au démarrage)
ADMIN_EMAIL=admin@portail.fr
ADMIN_PASSWORD=Admin123!

# Chemin de la base de données SQLite
# Railway : Volume monté sur /data → utiliser /data/portail.db
# Local   : changer en ./data/portail.db
DB_PATH=/data/portail.db

# Environnement
NODE_ENV=production
